# Nền tảng cấu hình AI Tutor MVP
#
# LLM (Gemini/OpenAI/OpenRouter) được cấu hình qua giao diện:
# Dashboard → Cài đặt → Cấu hình AI
# File lưu trữ: data/llm_config.json (tự tạo khi bạn lưu lần đầu)

# Telegram Bot Token (Để trống nếu không muốn chạy Telegram Bot)
TELEGRAM_BOT_TOKEN=

# SMTP Email (Dùng để gửi mã xác nhận OTP, sử dụng Gmail App Password)
SMTP_EMAIL=your@gmail.com
SMTP_APP_PASSWORD=your_app_password

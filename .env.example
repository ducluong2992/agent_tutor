# Nền tảng cấu hình AI Tutor MVP

# LLM Provider: 'gemini', 'openai', hoặc 'mock' (chạy offline giả lập cho phát triển)
LLM_PROVIDER=mock

# Google Gemini API Configuration
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# OpenAI API Configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Telegram Bot Token (Để trống nếu không muốn chạy Telegram Bot)
TELEGRAM_BOT_TOKEN=
